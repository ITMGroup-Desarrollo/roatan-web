---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Headers/HeaderBlog.astro";
import Footer from "../../components/Footer/Footer.astro";
import Menu from "../../components/Headers/Menu.astro";
import "../../assets/css/map.css";
import MapInteractive from "../../components/Map/MapInteractive.jsx";
import { translations } from "../../locales.js";

export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}
const lang = Astro.params.lang || "es";
const t = translations[lang] ?? translations["es"];
---

<Layout lang={lang}>
  <head>
    <!-- Leaflet CSS -->
    <link
      rel="stylesheet"
      href="https://unpkg.com/leaflet@1.7.1/dist/leaflet.css"
    />

    <!-- Leaflet JS -->
    <script is:inline src="https://unpkg.com/leaflet@1.7.1/dist/leaflet.js"
    ></script>
    <script is:inline set:html={`const idioma = "${lang}";`} />
  </head>

  <Menu lang={lang} />
  <!-- Menu spacing / padding -->
  <div style="height: 100px; background: var(--primary-color);"></div>

  <!-- Map Component -->
  <main id="main" class="shock-main mt-[2rem]">
    <MapInteractive lang={lang} />
  </main>

  <Footer lang={lang} videoFile="fondo-footer-gris.mp4" />

  <!-- Add jQuery since map.js depends on it -->
  <script is:inline src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

  <!-- Add map script at the end if it exists in public -->
  <script is:inline src={`${import.meta.env.BASE_URL}assets/js/vendor/map.js?v=2`}></script>

  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      // Esperar 600ms después de que cargue el DOM y activar todos los switches sin abrir los paneles
      setTimeout(function () {
        window.isInitialMapLoad = true;
        document
          .querySelectorAll(".leaflet-control-filter")
          .forEach(function (filter) {
            var checkbox = filter.querySelector(
              ".switch input[type='checkbox']",
            );
            if (checkbox && !checkbox.checked) {
              checkbox.click();
            }
          });
        window.isInitialMapLoad = false;
      }, 600);
    });
  </script>
</Layout>

<style>
  body {
    background-color: #f5f5f5;
  }
</style>
