---
import { translations } from "../../locales.js";
const lang = Astro.props?.lang ?? "es";
import "../../assets/css/footer.css";
import "../../assets/css/menu.css";
import "../../assets/css/main.css";
const t = translations[lang] ?? translations["es"];
import roatanLogo from "../../assets/img/logo/Roatan-LogoBlanco.png";
import fondosrc from "../../assets/video/fondo1.svg";
import { Image } from "astro:assets";
---

<footer
  class="relative w-screen h-[42vh] md:h-full lg:h-full bg-[transparent] z-5"
>
  <Image
    id="footerVideo"
    src={fondosrc}
    class="absolute w-auto h-full object-cover md:w-full md:h-full lg:h-full md:relative bottom-0 z-2"
    alt="palmita"
    loading="eager"
  />
  <!-- footer desktop -->
  <div
    class="absolute z-10 bottom-0 lg:bottom-10 flex flex-col gap-2 lg:gap-8 w-screen items-center"
  >
    <div
      class="lg:col-span-2 flex flex-col justify-center items-center gap-3 lg:gap-10"
    >
      <a href={`${import.meta.env.BASE_URL}${lang}/home/`}
        ><Image
          class="w-16 md:w-24 lg:w-36 xl:w-36 h-auto"
          src={roatanLogo}
          alt="logo"
          loading="eager"
        /></a
      >
    </div>
    <!-- links desktop -->
    <div class="flex justify-center">
      <nav
        class="text-white flex flex-col lg:flex-row text-center lg:text-left text-2xl lg:gap-5"
      >
        <a
          class="hover:text-[var(--secondary-color)]"
          href={`${import.meta.env.BASE_URL}${lang}/port-experience/`}
          >{t.menu["port-experience"]}</a
        >
        <a
          class="hover:text-[var(--secondary-color)]"
          href={`${import.meta.env.BASE_URL}${lang}/discover-beyond/`}
          >{t.menu["discover-beyond"]}</a
        >
        <a
          class="hover:text-[var(--secondary-color)]"
          href={`${import.meta.env.BASE_URL}${lang}/blog/`}>{t.menu.blog}</a
        >

        <a
          class="hover:text-[var(--secondary-color)]"
          href={`${import.meta.env.BASE_URL}${lang}/contact/`}
          >{t.menu.contact}</a
        >
        <a
          class="hover:text-[var(--secondary-color)]"
          href={`${import.meta.env.BASE_URL}${lang}/policy/`}
          >{t.footer.policy}</a
        >
      </nav>
    </div>
    <!-- <div class="footer-textbox flex w-full md:w-1/2 lg:w-1/2 my-8">
      <input
        type="text"
        class="form-control lg:text-base placeholder:italic uppercase h-6 lg:h-10 w-2/3 pl-4 bg-transparent text-white placeholder:text-white border-2 border-white rounded-s-full focus:outline-none focus:border-transparent focus:text-black focus:pl-4 focus:bg-white transition-all duration-300 ease-in-out"
        placeholder={t.footer.textboxPlaceholder}
      />
      <div
        class="button-container uppercase cursor-pointer flex items-center justify-center h-6 lg:h-10 w-1/3 border-2 rounded-e-full bg-white hover:bg-[var(--secondary-color)] outline-none border-white hover:border-[var(--secondary-color)] transition-all duration-300 ease-in-out font-lato"
      >
        <a class="button-sub font-lato lg:text-base">{t.footer.textboxButton}</a
        >
      </div>
    </div> -->
    <!-- iconos desktop -->
    <div class="col-span-1 flex justify-center flex-col gap-5">
      <nav
        class="text-white flex flex-col self-center text-right text-xl lg:gap-5"
      >
        <div class="flex flex-row-reverse gap-2 justify-right">
          <a
            class="social-link"
            href="https://www.tripadvisor.com.mx/Attraction_Review-g292019-d25290415-Reviews-Roatan_Cruise_Port-Roatan_Bay_Islands.html"
            target="_blank"
          >
            <svg
              class="w-8 h-8"
              viewBox="0 0 160 160"
              xmlns="http://www.w3.org/2000/svg"
            >
              <g class="social-icon-path">
                <path
