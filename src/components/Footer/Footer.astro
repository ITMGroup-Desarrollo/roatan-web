            </svg>
          </a>
        </div>
      </nav>
    </div>
    <!-- copyright desktop -->
    <div class="text-copyright text-white text-sm lg:text-base">
      <p>Copyright © 2026 │ By ITM Group</p>
    </div>
  </div>
</footer>

<script is:inline>
  const video = document.getElementById("footerVideo");
  if (video) {
    video.muted = true;
    video.defaultMuted = true;
    video.playsInline = true;

    // Intenta reproducirlo automáticamente
    window.addEventListener("load", () => {
      video.play().catch(() => {
        // En algunos casos Safari aún requiere interacción
      });
    });
  }
</script>
